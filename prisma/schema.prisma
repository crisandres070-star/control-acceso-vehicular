generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id            Int      @id @default(autoincrement())
  name          String
  licensePlate  String   @unique @map("license_plate")
  codigoInterno String   @default("PENDIENTE") @map("codigo_interno")
  rut           String   @unique
  vehicleType   String   @map("vehicle_type")
  brand         String
  company       String
  accessStatus  String   @map("access_status")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("vehicles")
}

model AccessLog {
  id            Int      @id @default(autoincrement())
  licensePlate  String   @map("license_plate")
  codigoInterno String? @map("codigo_interno")
  name          String
  result        String
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([licensePlate])
  @@map("access_logs")
}